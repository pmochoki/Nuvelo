# API base for the browser:
# - Leave empty to use same-origin `/api` (Vercel serverless in repo `/api` — listings, etc.).
# - Set a full URL only if the API is hosted elsewhere (CORS must allow your site).
# VITE_API_URL=https://example.com/api
VITE_API_URL=

# Local dev: run `vercel dev` from the repo root (port 3000) so `/api/*` exists; `npm run dev` in `web/` proxies /api → 127.0.0.1:3000.
# If the API is unreachable, new listings are saved to localStorage and the post flow still completes.

# /admin.html gate (embedded at build time). Override in production.
# VITE_ADMIN_PASSWORD=

# Vercel serverless: upstream URL for routes that still proxy (auth/login, admin). Listings use in-function storage by default.
# LISTINGS_BACKEND_URL=https://your-legacy-api.example.com

# Supabase (https://supabase.com/dashboard) — required for OAuth, magic link, and SMS OTP
# Production (e.g. nuvelo.one on Vercel): add these under Project → Settings → Environment Variables
# for Production, then trigger a new deployment so Vite can embed them at build time.
#
# Default project URL:
#   VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# After you enable a Supabase custom domain (paid add-on + DNS), point this at your subdomain instead, e.g.:
#   VITE_SUPABASE_URL=https://api.nuvelo.one
# Anon key is unchanged. Docs: https://supabase.com/docs/guides/platform/custom-domains
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: override OAuth / magic-link return URL (production default is https://nuvelo.one)
# VITE_AUTH_REDIRECT_URL=https://nuvelo.one

# Supabase Dashboard → Authentication → Providers: enable Google and/or Facebook with client IDs/secrets.
# Google Cloud → OAuth client → Authorized redirect URIs must list EVERY callback you use, e.g. BOTH:
#   https://<project-ref>.supabase.co/auth/v1/callback
#   https://api.nuvelo.one/auth/v1/callback
# (add the second line only after your custom domain is activated in Supabase)
# Meta (Facebook Login): same callback URLs under Valid OAuth Redirect URIs.
